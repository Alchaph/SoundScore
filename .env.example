# ============================================================
# SoundScore — Self-Hosting Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ── Database ──────────────────────────────────────────
DB_ROOT_PASSWORD=change-me-db-password
DB_NAME=sound

# ── JWT ──────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET_KEY=change-me-jwt-secret-at-least-32-chars

# ── Mail (optional, leave MAIL_PASSWORD empty to skip email) ─
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=soundscore@example.com
MAIL_PASSWORD=

# ── Seeding ──────────────────────────────────────────
# Set to "false" to skip test data on first start
SEEDING_ENABLED=true

# ── CORS ─────────────────────────────────────────────
# Comma-separated allowed origins (your domain + dev servers)
# Example: https://your-domain.com,http://localhost:4200,http://localhost:8888
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8888

# ── App Port ─────────────────────────────────────────
APP_PORT=8888

# ── Cloudflare Tunnel (optional) ────────────────────
# Get your tunnel token from Cloudflare Zero Trust dashboard
# Leave empty to skip tunnel
CLOUDFLARE_TUNNEL_TOKEN=
