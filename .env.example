# ============================================================
# SoundScore — Self-Hosting Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ── Database ──────────────────────────────────────────
DB_ROOT_PASSWORD=change-me-db-password
DB_NAME=sound

# ── JWT ──────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET_KEY=change-me-jwt-secret-at-least-32-chars

# ── Mail (optional, leave MAIL_PASSWORD empty to skip email) ─
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=soundscore@example.com
MAIL_PASSWORD=

# ── Seeding ──────────────────────────────────────────
# Set to "false" to skip test data on first start
SEEDING_ENABLED=true

# ── CORS ─────────────────────────────────────────────
# Comma-separated allowed origins (browser dev server, etc.)
# In production behind reverse proxy, this can stay empty
CORS_ALLOWED_ORIGINS=https://soundscore.chlarc.ch,http://localhost:4200,http://localhost:8888

# ── App Port ─────────────────────────────────────────
APP_PORT=8888

# ── Cloudflare Tunnel (optional) ────────────────────
# Get token: cloudflared tunnel token 8e20f0f1-e3dc-466e-9b44-e4c84cd5cdce
# Leave empty to skip tunnel
CLOUDFLARE_TUNNEL_TOKEN=
